# ── Required ──────────────────────────────────────────────────────────────────

# Coordinator URL (no trailing slash)
OBSIDEO_COORDINATOR_URL=https://coordinator.obsideo.io

# Tailscale auth key (generate at https://login.tailscale.com/admin/settings/keys)
# Use a reusable key so restarts work without re-auth.
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx

# Your tailnet domain (find at https://login.tailscale.com/admin/dns)
TS_TAILNET=tail1234.ts.net

# ── Optional ──────────────────────────────────────────────────────────────────

# Tailscale hostname for this node (default: obsideo-provider)
# Your provider will be reachable at https://{TS_HOSTNAME}.{TS_TAILNET}
TS_HOSTNAME=obsideo-provider

# AKT wallet address for earning rewards (can add later)
OBSIDEO_WALLET_ADDRESS=

# Storage capacity to advertise in bytes (default: 10 GB)
OBSIDEO_CAPACITY_BYTES=10737418240

# Provider ID from a previous registration (leave empty for auto-register)
OBSIDEO_PROVIDER_ID=

# Provider API port (default: 3334)
OBSIDEO_PROVIDER_PORT=3334

# Extra Tailscale args (default: advertise obsideo tag)
TS_EXTRA_ARGS=--advertise-tags=tag:obsideo
