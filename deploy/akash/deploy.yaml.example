---
# ============================================================
# Akash SDL - obsideo data farmer (storage provider)
# ============================================================
# Direct mode: no Tailscale sidecar. Akash ingress provides the
# public endpoint. Set OBSIDEO_PROVIDER_ADDRESS to the ingress
# URL after your first deployment.
#
# Deploy flow:
#   1. Deploy this SDL (leave OBSIDEO_PROVIDER_ADDRESS empty)
#   2. Check lease status to get the ingress URL
#   3. Update OBSIDEO_PROVIDER_ADDRESS with the ingress URL
#   4. Re-deploy (update + send-manifest) to trigger registration
# ============================================================

version: "2.0"

services:
  provider:
    image: golang:1.22-alpine
    command:
      - "sh"
      - "-c"
      - |
        set -e
        echo "=== obsideo data farmer on Akash ==="

        # --- System packages ---
        apk add --no-cache git ca-certificates curl jq openssl bash

        # --- Build provider binary if not cached ---
        BINARY=/data/bin/datafarmer
        VERSION_FILE=/data/bin/datafarmer.version
        mkdir -p /data/bin

        if [ ! -f "$BINARY" ] || [ "$(cat $VERSION_FILE 2>/dev/null)" != "$PROVIDER_VERSION" ]; then
          echo "Building datafarmer (version: $PROVIDER_VERSION)..."
          rm -rf /build
          mkdir -p /build
          git clone -b feature/remove-ipfs --depth 1 https://${GITHUB_TOKEN}@github.com/Regan-Milne/obsideo-drive.git /build/obsideo-drive
          cd /build/obsideo-drive/provider
          CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o "$BINARY" .
          echo "$PROVIDER_VERSION" > "$VERSION_FILE"
          rm -rf /build
          echo "Build complete: $(ls -lh $BINARY | awk '{print $5}')"
        else
          echo "Cached binary found (version: $PROVIDER_VERSION) -- skipping build."
        fi

        # --- Copy entrypoint and run ---
        # We inline the entrypoint logic here since we build from source
        # and don't have the Docker image entrypoint.sh available.

        DATA_DIR="/data/provider"
        COORD="${OBSIDEO_COORDINATOR_URL}"
        CAPACITY="${OBSIDEO_CAPACITY_BYTES:-10737418240}"
        WALLET="${OBSIDEO_WALLET_ADDRESS:-}"
        PROV_ID="${OBSIDEO_PROVIDER_ID:-}"
        PORT="${OBSIDEO_PROVIDER_PORT:-3334}"
        PROV_ADDR="${OBSIDEO_PROVIDER_ADDRESS:-}"

        STATE_FILE="${DATA_DIR}/.obsideo-state.json"
        IDENTITY_KEY="${DATA_DIR}/.identity_ed25519"
        COORD_PUB="${DATA_DIR}/coordinator_pub.pem"
        CONFIG_FILE="${DATA_DIR}/config.yaml"

        mkdir -p "$DATA_DIR"

        # Load persisted state
        if [ -z "$PROV_ID" ] && [ -f "$STATE_FILE" ]; then
          SAVED_ID=$(jq -r '.provider_id // empty' "$STATE_FILE" 2>/dev/null || true)
          if [ -n "$SAVED_ID" ]; then PROV_ID="$SAVED_ID"; echo "[provider] restored provider_id: $PROV_ID"; fi
        fi

        # Fetch coordinator public key
        echo "[provider] fetching coordinator public key..."
        RETRY=0
        while true; do
          if curl -fsSL --max-time 10 "${COORD}/public-key" -o "$COORD_PUB" 2>/dev/null; then
            echo "[provider] OK: coordinator pubkey saved"; break
          fi
          RETRY=$((RETRY + 1))
          if [ "$RETRY" -ge 30 ]; then echo "[provider] ERROR: coordinator unreachable after 30 retries"; exit 1; fi
          DELAY=$((RETRY < 5 ? RETRY * 2 : 10))
          echo "[provider] coordinator unreachable, retry in ${DELAY}s ($RETRY/30)..."
          sleep "$DELAY"
        done

        # Generate identity
        if [ ! -f "$IDENTITY_KEY" ]; then
          echo "[provider] generating ed25519 identity..."
          openssl genpkey -algorithm ed25519 -out "$IDENTITY_KEY" 2>/dev/null
          chmod 0600 "$IDENTITY_KEY"
        else
          echo "[provider] reusing existing identity"
        fi
        PUBLIC_KEY_HEX=$(openssl pkey -in "$IDENTITY_KEY" -pubout -outform DER 2>/dev/null \
          | tail -c 32 | od -An -tx1 | tr -d ' \n')
        echo "[provider] pubkey: ${PUBLIC_KEY_HEX:0:16}..."

        # Write config
        cat > "$CONFIG_FILE" <<YAML
        provider_id: "${PROV_ID}"
        coordinator_url: "${COORD}"
        wallet_address: "${WALLET}"
        server:
          host: "0.0.0.0"
          port: ${PORT}
          read_timeout: 7200
          write_timeout: 7200
        db:
          path: "${DATA_DIR}"
        tokens:
          public_key_path: "${COORD_PUB}"
        YAML
        # Remove leading spaces from heredoc indentation
        sed -i 's/^        //' "$CONFIG_FILE"

        # Start provider in background
        echo "[provider] starting datafarmer..."
        "$BINARY" start --config "$CONFIG_FILE" &
        PROVIDER_PID=$!
        trap "kill -TERM $PROVIDER_PID 2>/dev/null; wait $PROVIDER_PID" SIGTERM SIGINT

        # Wait for /health
        for i in $(seq 1 60); do
          if curl -fs --max-time 2 "http://localhost:${PORT}/health" >/dev/null 2>&1; then break; fi
          if ! kill -0 $PROVIDER_PID 2>/dev/null; then echo "[provider] ERROR: datafarmer exited"; exit 1; fi
          sleep 1
        done
        echo "[provider] OK: healthy on localhost:${PORT}"

        # Register (only if address is set and no existing ID)
        if [ -z "$PROV_ID" ] && [ -n "$PROV_ADDR" ]; then
          echo "[provider] registering with coordinator..."
          RESP_FILE=$(mktemp)
          REGISTERED=0
          for attempt in $(seq 1 20); do
            HTTP_CODE=$(curl -sS -o "$RESP_FILE" -w '%{http_code}' \
              -X POST -H 'Content-Type: application/json' \
              -d "{\"address\":\"${PROV_ADDR}\",\"connectivity\":\"direct\",\"public_key\":\"${PUBLIC_KEY_HEX}\",\"capacity_bytes\":${CAPACITY},\"wallet_address\":\"${WALLET}\"}" \
              --max-time 30 \
              "${COORD}/internal/providers/register" 2>/dev/null || echo 000)
            if [ "$HTTP_CODE" = "200" ] || [ "$HTTP_CODE" = "201" ]; then REGISTERED=1; break; fi
            echo "[provider] WARNING: registration attempt $attempt/20 failed (HTTP $HTTP_CODE): $(cat $RESP_FILE 2>/dev/null)"
            DELAY=$((attempt < 5 ? attempt * 3 : 20))
            sleep "$DELAY"
          done
          if [ "$REGISTERED" = "1" ]; then
            PROV_ID=$(jq -r '.id // empty' "$RESP_FILE" 2>/dev/null || true)
            PROV_STATUS=$(jq -r '.status // empty' "$RESP_FILE" 2>/dev/null || true)
            echo "[provider] OK: registered as $PROV_ID (status: $PROV_STATUS)"
            printf '{"provider_id":"%s"}\n' "$PROV_ID" > "$STATE_FILE"
            sed -i "s|^provider_id: .*|provider_id: \"${PROV_ID}\"|" "$CONFIG_FILE"
            # Restart to pick up provider_id
            kill -TERM $PROVIDER_PID 2>/dev/null || true
            wait $PROVIDER_PID 2>/dev/null || true
            echo "[provider] restarting with provider_id..."
            "$BINARY" start --config "$CONFIG_FILE" &
            PROVIDER_PID=$!
            trap "kill -TERM $PROVIDER_PID 2>/dev/null; wait $PROVIDER_PID" SIGTERM SIGINT
          else
            echo "[provider] WARNING: registration failed. Provider is running but unregistered."
            echo "[provider] Set OBSIDEO_PROVIDER_ADDRESS and redeploy to try again."
          fi
          rm -f "$RESP_FILE"
        elif [ -z "$PROV_ID" ]; then
          echo "[provider] no OBSIDEO_PROVIDER_ADDRESS set -- skipping registration"
          echo "[provider] set it to the Akash ingress URL and redeploy"
        else
          echo "[provider] provider_id already set: $PROV_ID"
        fi

        echo ""
        echo "============================================"
        echo "  DATA FARMER ONLINE (Akash)"
        echo "  ID:      ${PROV_ID:-unregistered}"
        echo "  Address: ${PROV_ADDR:-not set}"
        echo "  Storage: ${DATA_DIR}"
        echo "  Wallet:  ${WALLET:-not set}"
        echo "============================================"
        echo ""

        wait $PROVIDER_PID

    env:
      - GITHUB_TOKEN=YOUR_GITHUB_PAT_HERE
      - PROVIDER_VERSION=akash-test-1
      - OBSIDEO_COORDINATOR_URL=https://coordinator.obsideo.io
      - OBSIDEO_CAPACITY_BYTES=10737418240
      - OBSIDEO_WALLET_ADDRESS=
      - OBSIDEO_PROVIDER_PORT=3334
      # Set this after first deploy to the Akash ingress URL:
      - OBSIDEO_PROVIDER_ADDRESS=
    expose:
      - port: 3334
        as: 80
        to:
          - global: true
    params:
      storage:
        data:
          mount: /data
          readOnly: false

profiles:
  compute:
    provider:
      resources:
        cpu:
          units: 1
        memory:
          size: 2Gi
        storage:
          - size: 2Gi
          - name: data
            size: 5Gi
            attributes:
              persistent: true
              class: beta3
  placement:
    dcloud:
      pricing:
        provider:
          denom: uact
          amount: 3000

deployment:
  provider:
    dcloud:
      profile: provider
      count: 1
