# /etc/obsideo-provider/provider.env
# Configuration for the Obsideo storage provider service.

# ── Required ──────────────────────────────────────────────────────────────────

# Coordinator URL (no trailing slash)
OBSIDEO_COORDINATOR_URL=https://your-coordinator.example.com

# ── Storage ───────────────────────────────────────────────────────────────────

# Path to the data directory. Should be the mount point for your ZFS dataset.
OBSIDEO_DATA_DIR=/opt/obsideo-provider/data

# Storage capacity to advertise to the coordinator (bytes).
# Default: 10 GB. Set to match the space you want to allocate.
OBSIDEO_CAPACITY_BYTES=10737418240

# ── Identity ──────────────────────────────────────────────────────────────────

# Provider ID from a previous registration. Leave empty on first run;
# the bootstrap script will register and persist the assigned ID.
OBSIDEO_PROVIDER_ID=

# AKT wallet address for earning rewards (can add/change later via config)
OBSIDEO_WALLET_ADDRESS=

# ── Network ───────────────────────────────────────────────────────────────────

# Port the provider HTTP server listens on (default: 3334)
# Only change if you have a reason -- Tailscale Funnel maps 443 to this.
OBSIDEO_PROVIDER_PORT=3334
